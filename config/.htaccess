Options -Indexes
RewriteEngine On

# Force HTTPS (Railway provides HTTPS automatically)
RewriteCond %{HTTP:X-Forwarded-Proto} =http
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Service Worker — must be served from root scope
<FilesMatch "sw\.js$">
    Header set Service-Worker-Allowed "/"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# Manifest — no cache
<FilesMatch "manifest\.json$">
    Header set Cache-Control "no-cache"
    Header set Content-Type "application/manifest+json"
</FilesMatch>

# Cache static assets 7 days
<FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf)$">
    Header set Cache-Control "public, max-age=604800, immutable"
</FilesMatch>

# Block access to sensitive files
<FilesMatch "\.(sql|md|log|env|json|lock|toml)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Allow manifest.json specifically
<Files "manifest.json">
    Order allow,deny
    Allow from all
</Files>

# Block access to docker folder
<IfModule mod_rewrite.c>
    RewriteRule ^docker/ - [F,L]
</IfModule>

# Security headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
