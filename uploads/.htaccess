# Prevent PHP (and other server-side scripts) from executing inside this folder.
# Even if a malicious file is uploaded, it cannot be run as code.

<FilesMatch "\.(php|php\d|phtml|phar|shtml|cgi|pl|py|rb|asp|aspx|jsp)$">
    Require all denied
</FilesMatch>

# Allow safe image, video, audio, and document file types to be served
<FilesMatch "\.(jpg|jpeg|png|gif|webp|pdf|doc|docx|xls|xlsx|ppt|pptx|txt|zip|rar|mp4|mov|avi|webm|mkv|mp3|wav|ogg)$">
    Require all granted
</FilesMatch>
